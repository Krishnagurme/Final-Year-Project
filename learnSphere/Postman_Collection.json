{
  "name": "learnsphere",
  "displayName": "LearnSphere - Learning Management Platform",
  "description": "Complete API documentation for LearnSphere LMS",
  "version": "1.0.0",
  "schema": "https://schema.postman.com/json/collection/v2.1.0/collection.json",
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/courses?level=BEGINNER&category=Programming&limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "level", "value": "BEGINNER" },
                { "key": "category", "value": "Programming" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/courses",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "courses"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced Python\",\n  \"description\": \"Learn advanced Python concepts\",\n  \"category\": \"Programming\",\n  \"level\": \"ADVANCED\",\n  \"price\": 49.99,\n  \"learningOutcomes\": [\"Master decorators\", \"Understand async/await\"]\n}"
            }
          }
        },
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/courses/{{COURSE_ID}}/enroll",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "courses", "{{COURSE_ID}}", "enroll"]
            }
          }
        }
      ]
    },
    {
      "name": "Assessment",
      "item": [
        {
          "name": "Evaluate Prerequisites",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/assessments/evaluate-prerequisites",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "assessments", "evaluate-prerequisites"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"1\": \"Correct answer\",\n    \"2\": \"Another answer\"\n  },\n  \"courseLevel\": \"INTERMEDIATE\"\n}"
            }
          }
        },
        {
          "name": "Submit Assessment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },\n              { \"key\": \"Authorization\", \"value\": \"Bearer {{TOKEN}}\" }\n            ],\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/assessments/submit-assessment\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"assessments\", \"submit-assessment\"]\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\n  \\\"assessmentId\\\": \\\"{{ASSESSMENT_ID}}\\\",\n  \\\"answers\\\": [\n    { \\\"questionId\\\": \\\"1\\\", \\\"answer\\\": \\\"Option A\\\" }\n  ],\n  \\\"courseId\\\": \\\"{{COURSE_ID}}\\\"\n}\"\n            }\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"Users\",\n      \"item\": [\n        {\n          \"name\": \"Get Profile\",\n          \"request\": {\n            \"method\": \"GET\",\n            \"header\": [\n              { \"key\": \"Authorization\", \"value\": \"Bearer {{TOKEN}}\" }\n            ],\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/users/profile\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"users\", \"profile\"]\n            }\n          }\n        },\n        {\n          \"name\": \"Update Profile\",\n          \"request\": {\n            \"method\": \"PUT\",\n            \"header\": [\n              { \"key\": \"Content-Type\", \"value\": \"application/json\" },\n              { \"key\": \"Authorization\", \"value\": \"Bearer {{TOKEN}}\" }\n            ],\n            \"url\": {\n              \"raw\": \"{{BASE_URL}}/api/users/profile\",\n              \"host\": [\"{{BASE_URL}}\"],\n              \"path\": [\"api\", \"users\", \"profile\"]\n            },\n            \"body\": {\n              \"mode\": \"raw\",\n              \"raw\": \"{\n  \\\"firstName\\\": \\\"Jane\\\",\n  \\\"lastName\\\": \\\"Doe\\\",\n  \\\"bio\\\": \\\"Learning enthusiast\\\"\n}\"\n            }\n          }\n        }\n      ]\n    }\n  ],\n  \"variable\": [\n    { \"key\": \"BASE_URL\", \"value\": \"http://localhost:5000\" },\n    { \"key\": \"TOKEN\", \"value\": \"\" },\n    { \"key\": \"COURSE_ID\", \"value\": \"\" },\n    { \"key\": \"ASSESSMENT_ID\", \"value\": \"\" }\n  ]\n}\n